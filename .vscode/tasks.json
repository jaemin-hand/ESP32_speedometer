{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Arduino: Compile",
      "type": "shell",
      "command": "arduino-cli",
      "args": [
        "compile",
        "--clean",
        "--fqbn",
        "esp32:esp32:esp32p4",
        "--board-options",
        "ChipVariant=prev3,JTAGAdapter=default,PSRAM=enabled,USBMode=default,CDCOnBoot=default,MSCOnBoot=default,DFUOnBoot=default,UploadMode=default,PartitionScheme=default,FlashMode=qio,FlashFreq=80,FlashSize=16M,UploadSpeed=921600,DebugLevel=none,EraseFlash=none",
        "."
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Arduino: Upload",
      "type": "shell",
      "command": "arduino-cli",
      "args": [
        "compile",
        "--clean",
        "-u",
        "-p",
        "COM5",
        "--fqbn",
        "esp32:esp32:esp32p4",
        "--board-options",
        "ChipVariant=prev3,JTAGAdapter=default,PSRAM=enabled,USBMode=default,CDCOnBoot=default,MSCOnBoot=default,DFUOnBoot=default,UploadMode=default,PartitionScheme=default,FlashMode=qio,FlashFreq=80,FlashSize=16M,UploadSpeed=921600,DebugLevel=none,EraseFlash=none",
        "."
      ],
      "problemMatcher": []
    },
    {
      "label": "Arduino: Monitor",
      "type": "shell",
      "command": "arduino-cli",
      "args": [
        "monitor",
        "-p",
        "COM5",
        "--config",
        "115200"
      ],
      "problemMatcher": [],
      "isBackground": true
    },
    {
      "label": "Arduino: Monitor Stop",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-Command",
        "Get-CimInstance Win32_Process | Where-Object { $_.Name -eq 'arduino-cli.exe' -and $_.CommandLine -match 'monitor' -and $_.CommandLine -match 'COM5' } | ForEach-Object { Stop-Process -Id $_.ProcessId -Force }"
      ],
      "problemMatcher": []
    }
  ]
}
