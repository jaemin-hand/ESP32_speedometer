{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Arduino: Compile Raw",
      "type": "shell",
      "command": "arduino-cli",
      "args": [
        "compile",
        "--clean",
        "--fqbn",
        "esp32:esp32:esp32p4",
        "--board-options",
        "ChipVariant=prev3,JTAGAdapter=default,PSRAM=enabled,USBMode=default,CDCOnBoot=default,MSCOnBoot=default,DFUOnBoot=default,UploadMode=default,PartitionScheme=default,FlashMode=qio,FlashFreq=80,FlashSize=16M,UploadSpeed=921600,DebugLevel=none,EraseFlash=none",
        "."
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Fix compile_commands paths",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy", "Bypass",
        "-File", "${workspaceFolder}\\.vscode\\fix_compile_commands.ps1"
      ],
      "problemMatcher": []
    },
    {
      "label": "Arduino: Compile",
      "dependsOn": ["Arduino: Compile Raw", "Fix compile_commands paths"],
      "dependsOrder": "sequence",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Arduino: Upload",
      "type": "shell",
      "command": "arduino-cli",
      "args": [
        "compile",
        "--clean",
        "-u",
        "-p",
        "${input:serialPort}",
        "--fqbn",
        "esp32:esp32:esp32p4",
        "--board-options",
        "ChipVariant=prev3,JTAGAdapter=default,PSRAM=enabled,USBMode=default,CDCOnBoot=default,MSCOnBoot=default,DFUOnBoot=default,UploadMode=default,PartitionScheme=default,FlashMode=qio,FlashFreq=80,FlashSize=16M,UploadSpeed=921600,DebugLevel=none,EraseFlash=none",
        "."
      ],
      "problemMatcher": []
    },
    {
      "label": "Arduino: Monitor",
      "type": "shell",
      "command": "arduino-cli",
      "args": [
        "monitor",
        "-p",
        "${input:serialPort}",
        "--config",
        "115200"
      ],
      "problemMatcher": [],
      "isBackground": true
    },
    {
      "label": "Arduino: Monitor Stop",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-Command",
        "Get-CimInstance Win32_Process | Where-Object { $_.Name -eq 'arduino-cli.exe' -and $_.CommandLine -match 'monitor' -and $_.CommandLine -match '${input:serialPort}' } | ForEach-Object { Stop-Process -Id $_.ProcessId -Force }"
      ],
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "serialPort",
      "type": "promptString",
      "description": "Serial port for upload and monitor",
      "default": "COM5"
    }
  ]
}
